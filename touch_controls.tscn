; ── LEFT THUMB ─────────────────────────────────────────────────────────────
; Two 160×160 movement buttons anchored to the bottom-left corner.
; 80 px left margin clears the Dynamic Island / notch on either landscape
; orientation.  100 px bottom margin clears the Home indicator bar.

[node name="LeftBtn" type="TextureButton" parent="."]
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 80.0
offset_top = -260.0
offset_right = 240.0
offset_bottom = -100.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("2_left")
modulate = Color(1, 1, 1, 0.82)

[node name="RightBtn" type="TextureButton" parent="."]
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 255.0
offset_top = -260.0
offset_right = 415.0
offset_bottom = -100.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("3_right")
modulate = Color(1, 1, 1, 0.82)

; ── RIGHT THUMB — 2 × 2 action grid ───────────────────────────────────────
; All four buttons are 160×160, anchored to the bottom-right corner.
; 80 px right margin and 100 px bottom margin for safe area clearance.
; Layout (right edge → left, bottom → top):
;   Bottom row :  [ Swing ]  [ Jump  ]
;   Top row    :  [ Break ]  [ Roll  ]

