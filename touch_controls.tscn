[gd_scene format=3]

[ext_resource type="Script" path="res://touch_controls.gd" id="1_touch"]
[ext_resource type="Script" path="res://joystick.gd" id="2_joy"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Jump icon.png" id="4_jump"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Action axe.png" id="5_axe"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Power up.png" id="6_power"]

[node name="TouchControls" type="CanvasLayer"]
layer = 10
script = ExtResource("1_touch")

; ── LEFT THUMB — floating joystick ────────────────────────────────────────────
; Full-screen Control; joystick.gd only reacts to touches on the left 45%.
; The base snaps to wherever the thumb lands — no fixed dead spot to miss.

[node name="Joystick" type="Control" parent="."]
script = ExtResource("2_joy")

; ── RIGHT THUMB — action buttons ──────────────────────────────────────────────
;   [ Roll ] [ Break ]
;   [ Swing ] [ Jump ]   ← Jump largest, natural thumb rest

[node name="JumpBtn" type="TextureButton" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -265.0
offset_top = -255.0
offset_right = -80.0
offset_bottom = -80.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("4_jump")
modulate = Color(1, 1, 1, 0.85)

[node name="SwingBtn" type="TextureButton" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -455.0
offset_top = -270.0
offset_right = -295.0
offset_bottom = -105.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("5_axe")
modulate = Color(1, 1, 1, 0.82)

[node name="RollBtn" type="TextureButton" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -450.0
offset_top = -440.0
offset_right = -295.0
offset_bottom = -290.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("4_jump")
modulate = Color(0.4, 1.0, 0.75, 0.80)

[node name="BreakBtn" type="TextureButton" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -275.0
offset_top = -440.0
offset_right = -120.0
offset_bottom = -290.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("6_power")
modulate = Color(0.9, 0.5, 1.0, 0.80)

[connection signal="button_down" from="JumpBtn" to="." method="_on_jump_down"]
[connection signal="button_up" from="JumpBtn" to="." method="_on_jump_up"]
[connection signal="button_down" from="SwingBtn" to="." method="_on_swing_down"]
[connection signal="button_up" from="SwingBtn" to="." method="_on_swing_up"]
[connection signal="button_down" from="BreakBtn" to="." method="_on_break_down"]
[connection signal="button_up" from="BreakBtn" to="." method="_on_break_up"]
[connection signal="button_down" from="RollBtn" to="." method="_on_roll_down"]
[connection signal="button_up" from="RollBtn" to="." method="_on_roll_up"]
