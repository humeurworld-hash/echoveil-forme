[gd_scene format=3]

[ext_resource type="Script" path="res://touch_controls.gd" id="1_touch"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Left arrow .png" id="2_left"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Right arrow .png" id="3_right"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Jump icon.png" id="4_jump"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Action axe.png" id="5_axe"]
[ext_resource type="Texture2D" path="res://echoveil/UI/Controls /Power up.png" id="6_power"]

[node name="TouchControls" type="CanvasLayer"]
layer = 10
script = ExtResource("1_touch")

; ── LEFT THUMB — movement ──────────────────────────────────────────────────
; 175×160 buttons with a 50 px gap so the thumbs can't slip across by accident.
; 80 px from the left edge clears the Dynamic Island / notch.

[node name="LeftBtn" type="TextureButton" parent="."]
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 80.0
offset_top = -240.0
offset_right = 255.0
offset_bottom = -80.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("2_left")
modulate = Color(1, 1, 1, 0.82)

[node name="RightBtn" type="TextureButton" parent="."]
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 305.0
offset_top = -240.0
offset_right = 480.0
offset_bottom = -80.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("3_right")
modulate = Color(1, 1, 1, 0.82)

; ── RIGHT THUMB — actions ──────────────────────────────────────────────────
; Layout (right edge → left):
;
;          [ Roll ] [ Break ]
;          [ Swing ] [ JUMP ]  ← Jump is biggest, far-right, natural thumb rest
;
; Jump is 185×175 — visibly largest so the thumb finds it instantly.
; Swing is the secondary action, same row, 10 px to the left.
; Roll + Break are the utility tier above — smaller, offset so they
; don't get hit by accident.

[node name="JumpBtn" type="TextureButton" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -265.0
offset_top = -255.0
offset_right = -80.0
offset_bottom = -80.0
ignore_texture_size = true
stretch_mode = 0
texture_normal = ExtResource("4_jump")
modulate = Color(1, 1, 1, 0.85)

[node name="SwingBtn" type="TextureButton" parent="."]
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
